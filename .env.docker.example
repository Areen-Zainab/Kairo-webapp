# ────────────── Kairo-webapp Docker Environment Example ──────────────
# Copy this file to .env.docker and fill in your actual values.

# 1. AI API Keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=your_groq_api_key_2_here
MISTRAL_API_KEY=your_mistral_api_key_here
HF_TOKEN=your_huggingface_token_here

# 2. Database (IMPORTANT: Host is 'db', not 'localhost' when running in Docker)
DATABASE_URL=postgresql://postgres:your_password_here@db:5432/kairo_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=kairo_db

# 3. Backend Settings
PORT=5000
JWT_SECRET=your_jwt_secret_here
NODE_ENV=production

# 4. Supabase
PASS=your_supabase_db_password_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# 5. Bot & Features
BOT_NAME="Kairo Bot"
SHOW_BROWSER=false
WHISPER_MODE_ENABLED=true

# 6. Calendar & Frontend Integration
# Note: In Docker, the frontend typically runs on port 80 (standard HTTP)
FRONTEND_URL=http://localhost
ENABLE_CALENDAR_INTEGRATION=true
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/oauth/google/callback

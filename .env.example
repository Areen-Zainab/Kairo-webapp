# =============================================================================
# KAIRO — Environment Variables Reference
# =============================================================================
# Copy this file to .env at the repository root and fill in all values.
# The backend loads this file from ../../.env relative to backend/src/.
# Never commit the real .env file — it is listed in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# Port the Express server listens on
PORT=5000

# Comma-separated list of origins allowed by CORS (include your frontend URL)
FRONTEND_URL=http://localhost:5173


# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# Full PostgreSQL connection string — must point to a database with the
# pgvector extension installed and migrations applied (npx prisma migrate deploy)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/kairo?sslmode=require


# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------

# Secret used to sign and verify JWT access tokens — use a long random string
# Example (generate): node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET


# -----------------------------------------------------------------------------
# AI — LARGE LANGUAGE MODELS
# -----------------------------------------------------------------------------

# Groq API key — used by insight agents (decisions, topics, sentiment,
# action items, participant analysis) and Whisper Mode micro-recaps
GROQ_API_KEY=REPLACE_ME

# Optional second Groq key for multi-key provider rotation under load
GROQ_API_KEY_2=REPLACE_ME_OPTIONAL

# Mistral AI API key — used by the Summary Agent (mistral-small-latest)
MISTRAL_API_KEY=REPLACE_ME

# Hugging Face access token — required to download the pyannote diarization
# model on first run (pyannote/speaker-diarization-3.x requires HF login)
HF_TOKEN=REPLACE_ME


# -----------------------------------------------------------------------------
# SUPABASE (optional — for hosted Postgres and file storage)
# -----------------------------------------------------------------------------

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous (public) key — used by client-side operations
SUPABASE_ANON_KEY=REPLACE_ME

# Supabase service role key — used for server-side privileged operations
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME


# -----------------------------------------------------------------------------
# GOOGLE CALENDAR INTEGRATION
# -----------------------------------------------------------------------------

# Set to true to mount /api/calendar/* routes and enable the 15-minute
# calendar sync cron job. Leave false (or omit) to disable entirely.
ENABLE_CALENDAR_INTEGRATION=false

# Google OAuth 2.0 credentials — create at console.cloud.google.com
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME

# Must match the redirect URI registered in the Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/oauth/google/callback


# -----------------------------------------------------------------------------
# WHISPER MODE — LIVE MICRO-RECAPS
# -----------------------------------------------------------------------------

# Set to true to enable periodic AI recaps during live meetings
WHISPER_MODE_ENABLED=false

# Cron schedule for automatic recap generation (UTC)
# Default: every 5 minutes
WHISPER_MODE_CRON_SCHEDULE="*/5 * * * *"

# Maximum number of recaps stored per meeting in the database
WHISPER_MODE_MAX_STORED_RECAPS=10

# Maximum transcript characters sent to the LLM per recap call
WHISPER_MODE_TRANSCRIPT_MAX_CHARS=3000

# Maximum number of live meetings processed per cron tick
WHISPER_MODE_MAX_MEETINGS_PER_TICK=5

# Groq model used for recap generation
WHISPER_MODE_GROQ_MODEL=llama-3.1-8b-instant

# Token cap for each recap generation call
WHISPER_MODE_GROQ_MAX_TOKENS=180

# Temperature for recap generation (lower = more deterministic)
WHISPER_MODE_GROQ_TEMPERATURE=0.4

# Timeout in milliseconds for each Groq API call
WHISPER_MODE_GROQ_TIMEOUT_MS=60000

# Maximum number of retries on Groq API failure
WHISPER_MODE_GROQ_MAX_RETRIES=2

# Minimum interval in milliseconds between Groq calls for the same meeting
WHISPER_MODE_GROQ_MIN_INTERVAL_MS=12000


# -----------------------------------------------------------------------------
# SPEAKER IDENTIFICATION
# -----------------------------------------------------------------------------

# Set to true to enable real-time per-chunk speaker identification during
# live meetings using the persistent ECAPA-TDNN embedding encoder process
LIVE_SPEAKER_ID_ENABLED=true


# -----------------------------------------------------------------------------
# TASK MENTION WEBSOCKET
# -----------------------------------------------------------------------------

# Throttle interval (milliseconds) between task-mention WebSocket broadcasts
# for the same task in the same meeting (prevents event flooding)
TASK_MENTION_WS_THROTTLE_MS=5000


# -----------------------------------------------------------------------------
# FILE STORAGE PATHS
# -----------------------------------------------------------------------------

# Root directory where per-meeting audio chunks and transcript files are stored
# In Docker deployments this path should be mapped to a persistent named volume
MEETINGS_DATA_DIR=./data/meetings


# -----------------------------------------------------------------------------
# FRONTEND (.env in frontend/ — Vite reads VITE_* variables only)
# -----------------------------------------------------------------------------
# Create a separate frontend/.env file with the following:
#
# VITE_API_URL=http://localhost:5000/api
#
# In production, set VITE_API_URL to your deployed backend URL.
# =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                   @id @default(autoincrement())
  email                String                @unique
  passwordHash         String                @map("password_hash")
  name                 String
  profilePictureUrl    String?               @map("profile_picture_url")
  audioSampleUrl       String?               @map("audio_sample_url")
  timezone             String                @default("UTC")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  lastLogin            DateTime?             @map("last_login")
  isActive             Boolean               @default(true) @map("is_active")
  emailVerified        Boolean               @default(false) @map("email_verified")
  notificationSettings NotificationSettings?
  notifications        Notification[]
  userPreferences      UserPreferences?
  sessions             UserSession[]
  workspaceMembers     WorkspaceMember[]
  createdWorkspaces    Workspace[]           @relation("WorkspaceOwner")
  sentInvites          WorkspaceInvite[]     @relation("InvitedBy")
  receivedInvites      WorkspaceInvite[]     @relation("InvitedUser")
  createdMeetings      Meeting[]             @relation("MeetingCreator")
  meetingParticipants  MeetingParticipant[]  @relation("MeetingParticipants")
  meetingNotes         MeetingNote[]
  meetingFiles         MeetingFile[]
  confirmedActionItems ActionItem[]          @relation("ActionItemConfirmedBy")
  rejectedActionItems  ActionItem[]          @relation("ActionItemRejectedBy")

  @@map("users")
}

model UserSession {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  sessionToken String   @unique @map("session_token")
  deviceInfo   String?  @map("device_info")
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")
  lastActivity DateTime @default(now()) @updatedAt @map("last_activity")
  expiresAt    DateTime @map("expires_at")
  isActive     Boolean  @default(true) @map("is_active")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model UserPreferences {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")
  autoJoin        Boolean  @default(false) @map("auto_join")
  autoRecord      Boolean  @default(false) @map("auto_record")
  defaultDuration Int      @default(30) @map("default_duration")
  timezone        String   @default("UTC")
  themeMode       String   @default("light") @map("theme_mode")
  accentColor     String   @default("#007bff") @map("accent_color")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model NotificationSettings {
  id                      Int      @id @default(autoincrement())
  userId                  Int      @unique @map("user_id")
  emailMeetingReminders   Boolean  @default(true) @map("email_meeting_reminders")
  emailMeetingSummaries   Boolean  @default(true) @map("email_meeting_summaries")
  emailActionItems        Boolean  @default(true) @map("email_action_items")
  emailWeeklyDigest       Boolean  @default(false) @map("email_weekly_digest")
  pushMeetingStarting     Boolean  @default(true) @map("push_meeting_starting")
  pushMeetingJoined       Boolean  @default(false) @map("push_meeting_joined")
  pushMentionsAndReplies  Boolean  @default(true) @map("push_mentions_and_replies")
  pushActionItemsDue      Boolean  @default(true) @map("push_action_items_due")
  inAppMeetingUpdates     Boolean  @default(true) @map("in_app_meeting_updates")
  inAppTranscriptionReady Boolean  @default(true) @map("in_app_transcription_ready")
  inAppSharedWithYou      Boolean  @default(true) @map("in_app_shared_with_you")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model Workspace {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  code        String             @unique
  ownerId     Int                @map("owner_id")
  colorTheme  String?            @default("#9333ea") @map("color_theme")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  isActive    Boolean            @default(true) @map("is_active")
  settings    Json?
  members     WorkspaceMember[]
  invites     WorkspaceInvite[]
  logs        WorkspaceLog[]
  meetings    Meeting[]
  owner       User               @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("workspaces")
}

model Meeting {
  id              Int                 @id @default(autoincrement())
  workspaceId     Int                 @map("workspace_id")
  title           String
  description     String?
  meetingLink     String?             @map("meeting_link")
  platform        String?             // 'zoom', 'google-meet', 'teams', 'other'
  location        String?             // Physical location or additional details
  startTime       DateTime            @map("start_time")
  endTime         DateTime            @map("end_time")
  duration        Int                 // Duration in minutes
  meetingType     String              @default("scheduled") @map("meeting_type") // 'instant', 'scheduled', 'recurring'
  status          String              @default("scheduled") // 'scheduled', 'in-progress', 'completed', 'cancelled'
  isRecurring     Boolean             @default(false) @map("is_recurring")
  recurrenceRule  String?             @map("recurrence_rule") // iCal RRULE format
  createdById     Int                 @map("created_by_id")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  reminderSent    Boolean             @default(false) @map("reminder_sent")
  transcriptUrl   String?             @map("transcript_url")
  recordingUrl    String?             @map("recording_url")
  agenda          String?
  meetingSource   String?             @default("kairo") @map("meeting_source") // 'kairo', 'google-calendar', 'outlook', 'zoom', etc.
  metadata        Json?               // Additional flexible data
  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy       User                @relation("MeetingCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants    MeetingParticipant[]
  notes           MeetingNote[]
  files           MeetingFile[]
  actionItems     ActionItem[]

  @@index([workspaceId, startTime])
  @@index([status, startTime])
  @@map("meetings")
}

model ActionItem {
  id            Int       @id @default(autoincrement())
  meetingId     Int       @map("meeting_id")
  title         String
  description   String?   @db.Text
  assignee      String?
  dueDate       DateTime? @map("due_date")
  status        String    @default("pending")
  confirmedAt   DateTime? @map("confirmed_at")
  rejectedAt    DateTime? @map("rejected_at")
  confirmedBy   Int?      @map("confirmed_by")
  rejectedBy    Int?      @map("rejected_by")
  canonicalKey  String    @map("canonical_key")
  confidence    Float?    @default(0.0)
  sourceChunk   Int?      @map("source_chunk")
  firstSeenAt   DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt    DateTime  @updatedAt @map("last_seen_at")
  rawData       Json?     @map("raw_data")
  updateHistory Json?     @map("update_history")
  createdAt     DateTime  @default(now()) @map("created_at")

  meeting        Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  confirmedByUser User?  @relation("ActionItemConfirmedBy", fields: [confirmedBy], references: [id])
  rejectedByUser  User?  @relation("ActionItemRejectedBy", fields: [rejectedBy], references: [id])

  @@index([meetingId, status])
  @@index([meetingId, canonicalKey])
  @@index([status, lastSeenAt])
  @@map("action_items")
}

model MeetingNote {
  id          Int      @id @default(autoincrement())
  meetingId   Int      @map("meeting_id")
  userId      Int      @map("user_id")
  content     String
  type        String   @default("manual") // 'manual' | 'timeline'
  timestamp   Int      @default(0)        // seconds into recording; 0 for untimed
  color       String   @default("#3b82f6")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Denormalize author name for convenience in UI and history
  authorName  String?  @map("author_name")

  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([meetingId, timestamp])
  @@index([userId])
  @@map("meeting_notes")
}

model MeetingFile {
  id          Int      @id @default(autoincrement())
  meetingId   Int      @map("meeting_id")
  userId      Int      @map("user_id")
  filename    String   // Original filename
  filepath    String   // Relative path from meeting_data base dir: {meetingId}_.../uploads/{filename}
  fileSize    BigInt   @map("file_size") // Size in bytes
  mimeType    String?  @map("mime_type")
  fileType    String?  @map("file_type") // 'pdf', 'image', 'document', 'presentation', 'other'
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Denormalize uploader name for convenience
  uploaderName String? @map("uploader_name")

  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([userId])
  @@map("meeting_files")
}

model MeetingParticipant {
  id              Int      @id @default(autoincrement())
  meetingId       Int      @map("meeting_id")
  userId          Int      @map("user_id")
  role            String   @default("participant") // 'host', 'co-host', 'participant', 'optional'
  status          String   @default("invited") // 'invited', 'accepted', 'declined', 'tentative', 'attended'
  joinedAt        DateTime? @map("joined_at")
  leftAt          DateTime? @map("left_at")
  responseTime    DateTime? @map("response_time")
  meeting         Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user            User     @relation("MeetingParticipants", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@map("meeting_participants")
}

model WorkspaceLog {
  id          Int       @id @default(autoincrement())
  workspaceId Int       @map("workspace_id")
  userId      Int?      @map("user_id")
  action      String    // Type of action: 'created', 'updated', 'member_invited', 'member_joined', 'member_removed', 'settings_changed', etc.
  title       String    // Human-readable title
  description String    // Detailed description of the action
  metadata    Json?     // Additional data (e.g., what changed, who was affected)
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("workspace_logs")
}

model WorkspaceMember {
  id          Int       @id @default(autoincrement())
  workspaceId Int       @map("workspace_id")
  userId      Int       @map("user_id")
  role        String    @default("member")
  joinedAt    DateTime  @default(now()) @map("joined_at")
  isActive    Boolean   @default(true) @map("is_active")
  permissions Json?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model WorkspaceInvite {
  id            Int       @id @default(autoincrement())
  workspaceId   Int       @map("workspace_id")
  invitedEmail  String    @map("invited_email")
  invitedUserId Int?      @map("invited_user_id")
  invitedBy     Int       @map("invited_by")
  role          String    @default("member")
  status        String    @default("pending") // 'pending', 'accepted', 'rejected', 'expired'
  sentAt        DateTime  @default(now()) @map("sent_at")
  respondedAt   DateTime? @map("responded_at")
  expiresAt     DateTime? @map("expires_at")
  token         String    @unique
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter       User      @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: Cascade)
  invitedUser   User?     @relation("InvitedUser", fields: [invitedUserId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, invitedEmail])
  @@map("workspace_invites")
}

model Notification {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  title          String
  message        String
  type           String
  priority       String   @default("medium")
  workspace      String?
  isRead         Boolean  @default(false) @map("is_read")
  actionRequired Boolean  @default(false) @map("action_required")
  relatedId      String?  @map("related_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

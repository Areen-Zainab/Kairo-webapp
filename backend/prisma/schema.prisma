// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String    @map("password_hash")
  name              String
  profilePictureUrl String?   @map("profile_picture_url")
  audioSampleUrl    String?   @map("audio_sample_url")
  timezone          String    @default("UTC")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  lastLogin         DateTime? @map("last_login")
  isActive          Boolean   @default(true) @map("is_active")
  emailVerified     Boolean   @default(false) @map("email_verified")
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret   String?   @map("two_factor_secret")

  // Relations
  sessions          UserSession[]
  notifications     Notification[]
  createdWorkspaces Workspace[] @relation("WorkspaceOwner")
  workspaceMembers  WorkspaceMember[]
  createdTasks      Task[] @relation("TaskCreator")
  taskAssignments   TaskAssignee[]
  meetingOrganizer  Meeting[] @relation("MeetingOrganizer")
  meetingParticipants MeetingParticipant[]
  uploadedFiles     FileStorage[] @relation("FileUploader")
  userPreferences   UserPreferences?
  notificationSettings NotificationSettings?

  @@map("users")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  sessionToken String   @unique @map("session_token")
  deviceInfo   String?  @map("device_info")
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")
  lastActivity DateTime @default(now()) @updatedAt @map("last_activity")
  expiresAt    DateTime @map("expires_at")
  isActive     Boolean  @default(true) @map("is_active")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model UserPreferences {
  id              String  @id @default(cuid())
  userId          String  @unique @map("user_id")
  autoJoin        Boolean @default(true) @map("auto_join")
  autoRecord      Boolean @default(false) @map("auto_record")
  defaultDuration Int     @default(60) @map("default_duration")
  timezone        String  @default("UTC")
  themeMode       String  @default("dark") @map("theme_mode")
  accentColor     String  @default("#9333ea") @map("accent_color")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model NotificationSettings {
  id                        String  @id @default(cuid())
  userId                    String  @unique @map("user_id")
  emailMeetingReminders     Boolean @default(true) @map("email_meeting_reminders")
  emailMeetingSummaries     Boolean @default(true) @map("email_meeting_summaries")
  emailActionItems          Boolean @default(true) @map("email_action_items")
  emailWeeklyDigest         Boolean @default(false) @map("email_weekly_digest")
  pushMeetingStarting       Boolean @default(true) @map("push_meeting_starting")
  pushMeetingJoined         Boolean @default(false) @map("push_meeting_joined")
  pushMentionsAndReplies    Boolean @default(true) @map("push_mentions_and_replies")
  pushActionItemsDue        Boolean @default(true) @map("push_action_items_due")
  inAppMeetingUpdates       Boolean @default(true) @map("in_app_meeting_updates")
  inAppTranscriptionReady   Boolean @default(true) @map("in_app_transcription_ready")
  inAppSharedWithYou        Boolean @default(true) @map("in_app_shared_with_you")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model Notification {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  type              String   // meeting_reminder, meeting_starting, task_assigned, etc.
  title             String
  message           String
  isRead            Boolean  @default(false) @map("is_read")
  relatedEntityType String?  @map("related_entity_type")
  relatedEntityId   String?  @map("related_entity_id")
  createdAt         DateTime @default(now()) @map("created_at")
  readAt            DateTime? @map("read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// Placeholder models for future implementation
model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  code        String   @unique
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  isActive    Boolean  @default(true) @map("is_active")
  settings    Json?

  owner   User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members WorkspaceMember[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  role        String   @default("member")
  joinedAt    DateTime @default(now()) @map("joined_at")
  invitedBy   String?  @map("invited_by")
  isActive    Boolean  @default(true) @map("is_active")
  permissions Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Task {
  id              String    @id @default(cuid())
  workspaceId     String    @map("workspace_id")
  projectId       String?   @map("project_id")
  title           String
  description     String?
  status          String    @default("todo")
  priority        String    @default("medium")
  dueDate         DateTime? @map("due_date")
  createdBy       String    @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  estimatedHours  Float?    @map("estimated_hours")
  actualHours     Float?    @map("actual_hours")
  parentTaskId    String?   @map("parent_task_id")
  meetingContext  Json?     @map("meeting_context")

  creator     User           @relation("TaskCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  assignees   TaskAssignee[]
  parentTask  Task?          @relation("TaskParent", fields: [parentTaskId], references: [id])
  subtasks    Task[]         @relation("TaskParent")

  @@map("tasks")
}

model TaskAssignee {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String  @map("assigned_by")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@map("task_assignees")
}

model Meeting {
  id                String   @id @default(cuid())
  workspaceId       String   @map("workspace_id")
  title             String
  description       String?
  meetingType       String   @default("other") @map("meeting_type")
  status            String   @default("scheduled")
  scheduledDate     DateTime @map("scheduled_date")
  scheduledTime     String   @map("scheduled_time")
  durationMinutes   Int      @default(60) @map("duration_minutes")
  organizerId       String   @map("organizer_id")
  location          String?
  meetingUrl        String?  @map("meeting_url")
  recordingUrl      String?  @map("recording_url")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organizer    User                @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  participants MeetingParticipant[]

  @@map("meetings")
}

model MeetingParticipant {
  id        String   @id @default(cuid())
  meetingId String   @map("meeting_id")
  userId    String   @map("user_id")
  status    String   @default("invited")
  joinedAt  DateTime? @map("joined_at")
  leftAt    DateTime? @map("left_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@map("meeting_participants")
}

model FileStorage {
  id               String   @id @default(cuid())
  workspaceId      String   @map("workspace_id")
  filename         String
  originalFilename String   @map("original_filename")
  filePath         String   @map("file_path")
  fileType         String   @map("file_type")
  fileSize         BigInt   @map("file_size")
  mimeType         String?  @map("mime_type")
  uploadedBy       String   @map("uploaded_by")
  createdAt        DateTime @default(now()) @map("created_at")

  uploader User @relation("FileUploader", fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@map("file_storage")
}

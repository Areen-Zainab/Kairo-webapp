# Copy this file to `.env` and fill in your real values.
#
# This template documents the new Whisper Mode environment variables.
# (Your existing repo may already require additional vars such as `DATABASE_URL`,
#  `JWT_SECRET`, and Supabase keys; see `backend/.env` for those.)

# Whisper Mode (micro-recaps during meetings)
WHISPER_MODE_ENABLED=false
WHISPER_MODE_CRON_SCHEDULE="*/5 * * * *" # UTC
WHISPER_MODE_MAX_STORED_RECAPS=10
WHISPER_MODE_TRANSCRIPT_MAX_CHARS=3000
WHISPER_MODE_MAX_MEETINGS_PER_TICK=5

# Groq generation tuning (used by WhisperMode)
WHISPER_MODE_GROQ_MODEL="llama-3.1-8b-instant"
WHISPER_MODE_GROQ_MAX_TOKENS=180
WHISPER_MODE_GROQ_TEMPERATURE=0.4
WHISPER_MODE_GROQ_TIMEOUT_MS=60000
WHISPER_MODE_GROQ_MAX_RETRIES=2
WHISPER_MODE_GROQ_MIN_INTERVAL_MS=12000

# Required Groq keys for WhisperMode when enabled
GROQ_API_KEY=REPLACE_ME
GROQ_API_KEY_2=REPLACE_ME_OPTIONAL

